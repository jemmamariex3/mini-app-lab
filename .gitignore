# Node dependencies
# Generated when running npm install - these should be reinstalled from package.json
node_modules/

# Expo
# Temporary development files and cache generated by Expo CLI during development
.expo/
.expo-shared/

# Expo web builds
# Build output directories for web platform - regenerated during build process
dist/
web-build/

# Logs
# Debug and error logs from npm/yarn - not needed in version control
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
# Local configuration files that may contain sensitive data like API keys
.env
.env.local
.env.*.local

# macOS
# System files generated by macOS - not relevant to the project
.DS_Store

# IDE settings
# Editor-specific configuration folders - developers should use their own preferences
.vscode/
.idea/

# TypeScript build files
# Generated TypeScript declaration files - can be regenerated from source
*.tsbuildinfo
